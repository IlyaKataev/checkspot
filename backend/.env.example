DATABASE_URL=postgresql+asyncpg://checkspot:checkspot@localhost:5432/checkspot
JWT_SECRET=change-me-to-random-secret-32-chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

TELEGRAM_BOT_TOKEN=your-bot-token-here
# WEBHOOK_URL=https://your-domain.com  # только в продакшене

MEDIA_DIR=./media/photos

# 2GIS API ключ для геокодирования (получить на pro.2gis.ru, бесплатно 1000/день)
# Без ключа — fallback на Nominatim (хуже для РФ)
TWOGIS_API_KEY=

# AI модерация (выключена в MVP)
AI_MODERATION_ENABLED=false
ANTHROPIC_API_KEY=

# CORS — список через запятую
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
